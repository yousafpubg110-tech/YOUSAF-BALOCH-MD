# ═══════════════════════════════════════
# [1] SESSION — REQUIRED
# Get from pairing repo: node pairing.js
# ═══════════════════════════════════════
SESSION_ID=your_session_id_here

# ═══════════════════════════════════════
# [2] BOT BASIC SETTINGS
# ═══════════════════════════════════════
PREFIX=.
MODE=public
APP_NAME=YOUSAF-BALOCH-MD
TIMEZONE=Asia/Karachi
LANGUAGE=en

# ═══════════════════════════════════════
# [3] DEPLOYER / BOT ADMIN
# Number without + sign
# Multiple: 923001234567,923007654321
# ═══════════════════════════════════════
DEPLOYER_NUMBER=923710636110

# ═══════════════════════════════════════
# [4] DATABASE
# Free MongoDB Atlas: https://www.mongodb.com/atlas
# Leave empty to use local JSON
# ═══════════════════════════════════════
MONGODB_URI=
DB_PATH=./database

# ═══════════════════════════════════════
# [5] BOT MAIN SETTINGS
# Commands: alive, ping, runtime, owner, support, script
# ═══════════════════════════════════════
