# Used in: lib/logger.js
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=info
LOG_FILE=./logs/bot.log
LOG_ERRORS=true
LOG_COMMANDS=true

