#          economy-work.js, economy-shop.js,
#          economy-leaderboard.js, game-*.js
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
START_BALANCE=500
DAILY_REWARD=200
WORK_MIN=50
WORK_MAX=150
TAX_RATE=0.05
MAX_BANK=50000
ECONOMY_CURRENCY=Coins

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗃️ DATABASE CONFIG
# Used in: lib/database.js
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DB_TYPE=json
DB_PATH=./data
MONGODB_URI=your_mongodb_uri_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚙️ BOT BEHAVIOR SETTINGS
# Used in: handler.js, lib/commandHandler.js
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AUTO_READ=true
AUTO_TYPING=true
AUTO_REACT=true
AUTO_ONLINE=true
PUBLIC_MODE=true
SELF_MODE=false
ANTI_SPAM=true
ANTI_SPAM_LIMIT=5
COOLDOWN_DEFAULT=3
MAX_UPLOAD_SIZE=50

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🛡️ GROUP PROTECTION SETTINGS
# Used in: group-*.js, lib/middleware.js, lib/owner-guard.js
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MAX_WARN=3
WARN_ACTION=kick
ANTI_ABUSE=true
ANTI_LINK=false
ANTI_VV=false
AUTO_STICKER=false
ANTI_SPAM_GROUP=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
