# ╔══════════════════════════════════════════════════════════════════╗
# ║   YOUSAF-BALOCH-MD — Environment Variables Template             ║
# ║   Copy this file as .env and fill in your values                ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# HOW TO GET SESSION_ID:
#   1. Visit the pairing service below
#   2. Enter your WhatsApp number
#   3. Get pairing code, link device
#   4. Copy SESSION_ID sent to your WhatsApp
#   🔗 https://github.com/musakhanbaloch03-sad/YOUSAF-PAIRING-V1
#
# ⚠️  OWNER IDENTITY CANNOT BE CHANGED HERE — IT IS HARDCODED
# ═══════════════════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────────────────
SESSION_ID=YB_your_session_id_here

# ── BOT SETTINGS (Optional — these have defaults) ───────────────────
PREFIX=.
MODE=public
APP_NAME=YOUSAF-BALOCH-MD
TIMEZONE=Asia/Karachi
LANGUAGE=en

# ── FEATURES ────────────────────────────────────────────────────────
AUTO_READ=false
AUTO_READ_STATUS=false

# ── PLATFORM SPECIFIC ───────────────────────────────────────────────
# Heroku only (for keep-alive):
# HEROKU_APP_NAME=your-heroku-app-name

# MongoDB (optional, for premium plugins):
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/yousafmd
