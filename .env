SCRIPT_LINK=https://github.com/musakhanbaloch03-sad/YOUSAF-BALOCH-MD

# ═══════════════════════════════════════
# [6] AUTO FEATURES — true / false
# Commands: autoviewstatus, antidelete, autoreact, autoread
#           autotyping, autorecording, autobio, anticall
#           autoreply, autodownload
# ═══════════════════════════════════════
AUTO_READ=false
AUTO_READ_STATUS=true 
AUTO_LIKE_STATUS=true 
AUTO_REACT=false
AUTO_TYPING=false
AUTO_RECORDING=false
AUTO_BIO=false
AUTO_REPLY=true 
AUTO_DOWNLOAD=false
ANTI_DELETE=true 
ANTI_CALL=false

# ═══════════════════════════════════════
# [7] ANTI FEATURES — true / false
# Commands: antilink, antivv, antispam
# ═══════════════════════════════════════
ANTI_LINK=false
ANTI_BAD=true 
ANTI_SPAM=true
ANTI_VIEW_ONCE=true 

# ═══════════════════════════════════════
# [8] GROUP FEATURES
# Commands: add, kick, promote, demote, tagall, hidetag
#           warn, unwarn, groupopen, groupclose
# ═══════════════════════════════════════
