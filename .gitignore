# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# YOUSAF-BALOCH-MD — .gitignore
# Created by: Muhammad Yousaf Baloch
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Dependencies
node_modules/
package-lock.json

# Environment variables — NEVER commit these
.env
.env.local
.env.production

# Session files — NEVER commit these
session/
auth_info_baileys/
session.json
creds.json

# Database files
database/
*.db
*.sqlite

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Temporary files
tmp/
temp/
*.tmp
*.cache

# Media — downloaded files
media/*.mp3
media/*.mp4
media/*.jpg
media/*.png
media/*.gif
media/*.webp
media/*.opus

# Backup files
backups/
*.tar.gz
*.zip

# PM2
.pm2/
ecosystem.config.js
