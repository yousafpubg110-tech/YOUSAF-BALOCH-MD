{
  "name": "YOUSAF-BALOCH-MD",
  "description": "YOUSAF-BALOCH-MD | Premium WhatsApp Multi-Device Bot | Created by Muhammad Yousaf Baloch",
  "repository": "https://github.com/musakhanbaloch03-sad/YOUSAF-BALOCH-MD",
  "logo": "https://i.imgur.com/placeholder.png",
  "keywords": ["whatsapp", "bot", "baileys", "node"],
  "env": {
    "SESSION_ID": {
      "description": "Your Session ID from YOUSAF-PAIRING-V1. Get it from: https://github.com/musakhanbaloch03-sad/YOUSAF-PAIRING-V1",
      "required": true
    },
    "PREFIX": {
      "description": "Command prefix for bot (default: .)",
      "value": ".",
      "required": false
    },
    "MODE": {
      "description": "Bot mode: 'public' (everyone can use) or 'private' (owner only)",
      "value": "public",
      "required": false
    },
    "APP_NAME": {
      "description": "Custom display name for the bot",
      "value": "YOUSAF-BALOCH-MD",
      "required": false
    },
    "TIMEZONE": {
      "description": "Timezone for bot schedules (e.g. Asia/Karachi)",
      "value": "Asia/Karachi",
      "required": false
    },
    "AUTO_READ": {
      "description": "Auto-read incoming messages (true/false)",
      "value": "false",
      "required": false
    },
    "AUTO_READ_STATUS": {
      "description": "Auto-read WhatsApp status updates (true/false)",
      "value": "false",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "stack": "heroku-22"
}
